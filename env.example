# =============================================================================
# Genie API OBO RLS - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control (it contains secrets)
# =============================================================================

# =============================================================================
# BOT FRAMEWORK (Azure Bot Service)
# =============================================================================
# From: Azure Portal > Bot Services > Your Bot > Configuration
MICROSOFT_APP_ID=your-microsoft-app-id-here
MICROSOFT_APP_PASSWORD=your-microsoft-app-password-here
MICROSOFT_APP_TENANT_ID=your-azure-tenant-id-here

# OAuth connection name (must match Azure Bot OAuth Connection Settings)
OAUTH_CONNECTION_NAME=databricks-sso

# =============================================================================
# DATABRICKS GENIE API
# =============================================================================
# Workspace URL: Azure Portal > Databricks > Your Workspace
GENIE_DATABRICKS_HOST=https://your-workspace.azuredatabricks.net

# Genie Space ID: Databricks Workspace > Genie > Your Space > Settings
GENIE_GENIE_SPACE_ID=your-genie-space-id-here

# =============================================================================
# ACCOUNT-LEVEL TOKEN FEDERATION (for USER identity preservation)
# =============================================================================
# This project uses ACCOUNT-LEVEL token federation to preserve user identity
# for Unity Catalog Row-Level Security (RLS).
#
# Key difference from SP-level federation:
# - Account-level: NO client_id, token is for THE USER
# - SP-level: WITH client_id, token is for the Service Principal
#
# Account ID: Found in Databricks Account Console URL or Settings
DATABRICKS_ACCOUNT_ID=your-databricks-account-id-here

# Token exchange endpoint - MUST use ACCOUNT-LEVEL endpoint for user identity!
# Format: https://accounts.azuredatabricks.net/oidc/accounts/{ACCOUNT_ID}/v1/token
# If not set, the code constructs it from DATABRICKS_ACCOUNT_ID
GENIE_TOKEN_EXCHANGE_URL=

# Optional: Token scope and audience (usually not needed)
GENIE_TOKEN_SCOPE=
GENIE_TOKEN_AUDIENCE=

# Token cache TTL in seconds (default: 300 = 5 minutes)
GENIE_CACHE_TTL_SECONDS=300

# =============================================================================
# SCALING (Optional - for multi-instance deployments)
# =============================================================================
# Redis URL for shared token cache across instances
# Required for scaling beyond single instance (Azure App Service scale-out, AKS, etc.)
# Without Redis, each instance maintains its own cache, causing extra token exchanges
#
# Format: redis://[username:password@]host:port/db_number
# Azure Redis Cache: redis://:<access-key>@your-redis.redis.cache.windows.net:6380/0?ssl=true
#
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://:your-access-key@your-redis.redis.cache.windows.net:6380/0?ssl=true

# =============================================================================
# AZURE KEY VAULT (Optional - for production secret management)
# =============================================================================
AZURE_KEYVAULT_URL=

# =============================================================================
# APPLICATION INSIGHTS (Optional - for monitoring)
# =============================================================================
# From: Azure Portal > Application Insights > Your Resource > Overview
APPLICATIONINSIGHTS_CONNECTION_STRING=

# =============================================================================
# APP SERVICE URL
# =============================================================================
APP_SERVICE_URL=https://your-app-service.azurewebsites.net
